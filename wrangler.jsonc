{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "touchproof",
  "main": "./apps/web/deploy/cloudflareWorker.ts",
  "compatibility_date": "2026-07-10",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "touchproof.siraben.dev",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./apps/web/out",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "observability": {
    "enabled": true
  }
}
